{
  "name": "siaoynli/plugin-store",
  "description": "插件市场/仓库管理插件 — 基于 siaoynli/laravel-plugins",
  "version": "1.0.0",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "laravel",
    "plugin",
    "marketplace",
    "store",
    "plugin-manager"
  ],
  "authors": [
    {
      "name": "Siaoynli",
      "email": "siaoynli@126.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "laravel/framework": "^11.0",
    "siaoynli/laravel-plugins": "^1.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "Siaoynli\\PluginStore\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Siaoynli\\PluginStore\\Tests\\": "tests/"
    }
  },
  "extra": {
    "plugin": {
      "class": "Siaoynli\\PluginStore\\PluginStorePlugin"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
